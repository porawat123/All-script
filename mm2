-- [[ 1. Ghost Lag (ได้รับแรงบันดาลใจจากการเคลื่อนไหวของข่าวล่าสุด) ]] --
addToggle("👻 ระบบ Ghost Lag V3", function(s)
    _G.Ghost = s
    task.spawn(function()
        while _G.Ghost do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.Anchored = true
                task.wait(0.05)
                player.Character.HumanoidRootPart.Anchored = false
            end
            task.wait(0.12)
        end
    end)
end)

-- [[ 2. Silent Aim ]] --
addToggle("🔫 Silent Aim V2 (หัวฆาตกร)", function(s) _G.Aim = s end)
run.RenderStepped:Connect(function()
    if _G.Aim and player.Character:FindFirstChild("Gun") then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then
                player.Character.Gun.Handle.CFrame = CFrame.new(player.Character.Gun.Handle.Position, v.Character.Head.Position)
            end
        end
    end
end)

-- [[ 3. Player ESP (ได้รับแรงบันดาลใจจากสีของข่าวล่าสุด) ]] --
addToggle("🧿 Player ESP (สีข่าว)", function(s) _G.ESP = s end)
run.RenderStepped:Connect(function()
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character then
            local h = v.Character:FindFirstChild("Highlight")
            if _G.ESP then
                if not h then h = Instance.new("Highlight", v.Character) end
                -- สีแดงสดสำหรับฆาตกร และสีเขียวสดสำหรับคนธรรมดา
                h.FillColor = (v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife")) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                h.FillTransparency = 0.5
            elseif h then h:Destroy() end
        end
    end
end)

