-- [[ ฟังก์ชัน: สร้าง Toggle ที่ได้รับแรงบันดาลใจจากข่าวล่าสุด ]] --
local function addToggle(txt, callback)
    local active = false
    local tFrame = Instance.new("Frame", scroll)
    tFrame.Size = UDim2.new(0.95, 0, 0, 55)
    tFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tFrame.BackgroundTransparency = 0.3
    
    local tCorner = Instance.new("UICorner", tFrame)
    tCorner.CornerRadius = UDim.new(0, 10)
    
    local tLabel = Instance.new("TextLabel", tFrame)
    tLabel.Size = UDim2.new(0.7, 0, 1, 0)
    tLabel.Position = UDim2.new(0.05, 0, 0, 0)
    tLabel.Text = txt -- ชื่อฟังก์ชัน MM2
    tLabel.TextColor3 = Color3.new(0.9, 0.9, 0.9)
    tLabel.TextSize = 16
    tLabel.Font = Enum.Font.GothamSemibold
    tLabel.TextXAlignment = Enum.TextXAlignment.Left
    tLabel.BackgroundTransparency = 1

    local switch = Instance.new("TextButton", tFrame)
    switch.Size = UDim2.new(0, 50, 0, 25)
    switch.Position = UDim2.new(0.95, -50, 0.5, -12)
    switch.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    switch.Text = ""
    
    local sCorner = Instance.new("UICorner", switch)
    sCorner.CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("Frame", switch)
    dot.Size = UDim2.new(0, 21, 0, 21)
    dot.Position = UDim2.new(0, 2, 0.5, -10)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    switch.MouseButton1Click:Connect(function()
        active = not active
        -- การเคลื่อนไหวของสีที่ได้รับแรงบันดาลใจจากข่าวล่าสุด
        ts:Create(switch, TweenInfo.new(0.3), {BackgroundColor3 = active and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(60, 60, 60)}):Play()
        ts:Create(dot, TweenInfo.new(0.3), {Position = active and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)}):Play()
        callback(active)
    end)
end

